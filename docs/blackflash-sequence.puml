@startuml Blackflash — Full Project Sequence Diagram

title Blackflash Discord Music Bot\nFull Sequence Diagram

skinparam sequenceArrowThickness 1.5
skinparam sequenceGroupBorderThickness 1
skinparam noteBackgroundColor #FFFDE7
skinparam noteBorderColor #F9A825
skinparam sequenceLifeLineBorderColor #555
skinparam ParticipantBackgroundColor #E8F5E9
skinparam ParticipantBorderColor #388E3C

actor       "Discord User"         as User
participant "Discord API"          as Discord
box "Spring Application" #F3F4F6
  participant "BlackflashApplication"      as App
  participant "ObjectMapper\nConfiguration" as ObjMapper
  participant "LavalinkConfiguration"      as LavalinkConfig
  participant "SlashCommand\nListener"     as Listener
  participant "SlashCommand\nHandler"      as Handler
  participant "GuildMusicManager\nRegistry" as Registry
  participant "GuildMusic\nManager"        as MusicManager
  participant "TrackScheduler"             as Scheduler
  participant "AudioLoader"                as AudioLoader
  participant "DiscordConfiguration"       as DiscordConfig
  participant "Spring Actuator"            as Actuator
end box
participant "LavalinkClient\n(dev.arbjerg)" as LLClient
participant "Lavalink v4 Node\n(Docker :2333)" as LLNode
participant "Elasticsearch"        as Elastic

' ═══════════════════════════════════════════════════════
== Application Startup ==
' ═══════════════════════════════════════════════════════

[-> App : main(args)
activate App
App -> App : TimeZone.setDefault("Europe/Paris")
App -> App : SpringApplication.run(BlackflashApplication.class)
note right of App : @SpringBootApplication\nexcludes DataSourceAutoConfiguration\n& UserDetailsServiceAutoConfiguration

' --- Bean: JsonMapper ---
App -> ObjMapper : create @Bean jsonMapper()
activate ObjMapper
ObjMapper -> ObjMapper : configure SNAKE_CASE, NON_NULL,\nFAIL_ON_UNKNOWN_PROPERTIES=false,\nDateTimeFeature.WRITE_DATES_WITH_ZONE_ID,\nStringTrimmingDeserializer
ObjMapper --> App : JsonMapper bean ready
deactivate ObjMapper

' --- Bean: LavalinkClient ---
App -> LavalinkConfig : create @Bean lavalinkClient(token)
activate LavalinkConfig
LavalinkConfig -> LLClient ** : new LavalinkClient(\n  Helpers.getUserIdFromToken(token))
LavalinkConfig -> LLClient : loadBalancer\n  .addPenaltyProvider(\n    new VoiceRegionPenaltyProvider())
LavalinkConfig -> LLClient : addNode(NodeOptions:\n  name, ws://uri, password,\n  RegionFilter=EUROPE)
LLClient -> LLNode : WebSocket connect
activate LLNode
LLNode --> LLClient : connection established
LavalinkConfig -> LLClient : node.on(TrackStartEvent)\n  .subscribe(log info)
LavalinkConfig -> LLClient : on(ReadyEvent)\n  .subscribe(log info)
LavalinkConfig -> LLClient : on(StatsEvent)\n  .subscribe(log info)
LavalinkConfig -> LLClient : on(EmittedEvent)\n  .subscribe(log info)
LLNode --> LLClient : ReadyEvent
LLClient -> LLClient : log "Node '<name>' is ready,\n  session id is '<id>'!"
LavalinkConfig --> App : LavalinkClient bean ready
deactivate LavalinkConfig

' --- Bean: GuildMusicManagerRegistry ---
App -> Registry : create @Component GuildMusicManagerRegistry\n  (inject LavalinkClient)
activate Registry
Registry -> Registry : managers = new ConcurrentHashMap<>()
Registry --> App : GuildMusicManagerRegistry bean ready
deactivate Registry

' --- Bean: SlashCommandListener ---
App -> Listener : create @Component SlashCommandListener\n  (inject LavalinkClient,\n   GuildMusicManagerRegistry,\n   List<SlashCommandHandler>)
activate Listener
note right of Listener : Each SlashCommandHandler impl (@Component)\nis auto-collected by Spring.\nEach handler defines its own CommandData.
Listener -> Listener : @PostConstruct init()
Listener -> LLClient : on(TrackStartEvent)\n  .subscribe(delegate to guild's\n  TrackScheduler via registry)
Listener -> LLClient : on(TrackEndEvent)\n  .subscribe(delegate to guild's\n  TrackScheduler via registry)
Listener --> App : SlashCommandListener bean ready
deactivate Listener

' --- Bean: DiscordConfiguration ---
App -> DiscordConfig : create @Configuration DiscordConfiguration\n  (inject SlashCommandListener, LavalinkClient)
activate DiscordConfig
DiscordConfig -> DiscordConfig : @PostConstruct initializeJDA()
DiscordConfig -> DiscordConfig : log "Initializing JDA,\n  registering listeners..."
DiscordConfig -> Discord : JDABuilder.createDefault(token)\n  .setEventPool(\n    Executors.newVirtualThreadPerTaskExecutor(), true)\n  .setVoiceDispatchInterceptor(\n    new JDAVoiceUpdateListener(lavalink))\n  .enableIntents(GUILD_MESSAGE_REACTIONS,\n    GUILD_MEMBERS, GUILD_PRESENCES,\n    GUILD_MESSAGES, GUILD_VOICE_STATES)\n  .enableCache(VOICE_STATE, ONLINE_STATUS, ACTIVITY)\n  .setActivity(Activity.listening(activity))\n  .setAutoReconnect(true)\n  .setMemberCachePolicy(ALL)\n  .setChunkingFilter(include(100))\n  .addEventListeners(listener)\n  .setAudioModuleConfig(\n    new AudioModuleConfig()\n      .withDaveSessionFactory(\n        new JDaveSessionFactory()))\n  .build().awaitReady()
activate Discord
Discord --> DiscordConfig : JDA instance (ready)
deactivate Discord
DiscordConfig -> DiscordConfig : log "JDA initialized successfully."
DiscordConfig --> App : DiscordConfiguration ready
deactivate DiscordConfig

note over Listener, Discord : Commands are registered when\nSlashCommandListener.onReady() fires\n(triggered by JDA ReadyEvent)

Discord -> Listener : ReadyEvent
activate Listener
Listener -> Listener : log "{bot} is ready!"
Listener -> Discord : jda.updateCommands()\n  .addCommands(\n    slashCommandHandlers.stream()\n      .map(SlashCommandHandler::commandData)\n      .toList())\n  .queue()
note right of Discord : Registers: /help, /join, /play (query),\n/skip, /loop, /shuffle, /leave, /stop\n(all GUILD context — each from its own handler)
Discord --> Listener : commands registered (async)
deactivate Listener

App --> App : Application context started\n(JDA events: one virtual thread per event)
deactivate App

' ═══════════════════════════════════════════════════════
== Periodic: Lavalink Stats Heartbeat ==
' ═══════════════════════════════════════════════════════

LLNode -> LLClient : StatsEvent (periodic)
LLClient -> LLClient : log "Node '<name>' has stats:\n  playing=X/Y (link count=Z)"

' ═══════════════════════════════════════════════════════
== Slash Command: /join ==
' ═══════════════════════════════════════════════════════

User -> Discord : /join
Discord -> Listener : SlashCommandInteractionEvent
activate Listener
note right of Listener : Guard: member must be in a voice channel.\nrequiresBotInVoiceChannel=false —\njoin manages its own bot-presence check.
Listener -> Handler : dispatch → SlashJoinCommandHandler\n  handle(event, guild)
activate Handler

alt Bot already in voice channel
  Handler -> Discord : reply(MESSAGE_BOT_ALREADY_IN_VOICE_CHANNEL)\n  .setEphemeral(true).queue()
else Bot NOT in voice channel
  Handler -> Handler : joinChannel(event)
  Handler -> Discord : jda.getDirectAudioController()\n  .connect(memberVoiceChannel)
  Handler -> Registry : getOrCreate(guildId)
  activate Registry
  Registry -> MusicManager ** : new GuildMusicManager(guildId, lavalink)
  activate MusicManager
  MusicManager -> Scheduler ** : new TrackScheduler(this)
  MusicManager --> Registry : GuildMusicManager
  deactivate MusicManager
  Registry --> Handler : GuildMusicManager
  deactivate Registry
  Handler -> Discord : reply("Joining your channel!").queue()
end

deactivate Handler
deactivate Listener

' ═══════════════════════════════════════════════════════
== Slash Command: /play ==
' ═══════════════════════════════════════════════════════

User -> Discord : /play query:"<track URL or search>"
Discord -> Listener : SlashCommandInteractionEvent
activate Listener
note right of Listener : requiresBotInVoiceChannel=false —\nplay joins automatically if needed.
Listener -> Handler : dispatch → SlashPlayCommandHandler\n  handle(event, guild)
activate Handler

alt Bot already in voice channel
  Handler -> Discord : event.deferReply(false).queue()
else Bot NOT in voice channel
  Handler -> Handler : slashJoinCommandHandler.joinChannel(event)
end

Handler -> Registry : getOrCreate(guildId)
Registry --> Handler : GuildMusicManager (manager)
Handler -> AudioLoader ** : new AudioLoader(event, manager)
Handler -> LLClient : lavalink.getOrCreateLink(guildId)\n  .loadItem(query)\n  .subscribe(audioLoader)
LLClient -> LLNode : REST POST /v4/loadtracks\n  ?identifier=<query>
deactivate Handler
deactivate Listener

alt Track loaded
  LLNode --> LLClient : TrackLoaded result
  LLClient -> AudioLoader : ontrackLoaded(result)
  activate AudioLoader
  AudioLoader -> AudioLoader : track.setUserData(\n  new UserData(userId))
  AudioLoader -> Scheduler : enqueue(track)
  activate Scheduler
  alt No current track playing
    Scheduler -> LLClient : link.createOrUpdatePlayer()\n  .setTrack(track)\n  .setVolume(50)\n  .setEndTime(track.length)\n  .subscribe()
    LLClient -> LLNode : WebSocket PLAY (guildId, track)
    LLNode -> Discord : audio stream (UDP / voice gateway)
    Discord -> User : 🎵 audio playback
  else Track already playing
    Scheduler -> Scheduler : queue.offer(track)
  end
  deactivate Scheduler
  AudioLoader -> Discord : hook.sendMessage(\n  "Added to queue: {title}\nRequested by: <@{id}>")
  deactivate AudioLoader

else Playlist loaded
  LLNode --> LLClient : PlaylistLoaded result
  LLClient -> AudioLoader : onPlaylistLoaded(result)
  activate AudioLoader
  AudioLoader -> Discord : hook.sendMessage(\n  "Added N tracks from {playlist}")
  AudioLoader -> Scheduler : enqueuePlaylist(tracks)
  activate Scheduler
  Scheduler -> Scheduler : queue.addAll(tracks)
  alt No current track playing
    Scheduler -> Scheduler : startTrack(queue.poll())
  end
  deactivate Scheduler
  deactivate AudioLoader

else Search result
  LLNode --> LLClient : SearchResult
  LLClient -> AudioLoader : onSearchResultLoaded(result)
  activate AudioLoader
  alt tracks not empty
    AudioLoader -> Discord : hook.sendMessage(\n  "Adding to queue: {firstTrack.title}")
    AudioLoader -> Scheduler : enqueue(firstTrack)
  else empty results
    AudioLoader -> Discord : hook.sendMessage("No tracks found!")
  end
  deactivate AudioLoader

else No matches
  LLNode --> LLClient : NoMatches
  LLClient -> AudioLoader : noMatches()
  activate AudioLoader
  AudioLoader -> Discord : hook.sendMessage(\n  "No matches found for your input!")
  deactivate AudioLoader

else Load failed
  LLNode --> LLClient : LoadFailed
  LLClient -> AudioLoader : loadFailed(result)
  activate AudioLoader
  AudioLoader -> Discord : hook.sendMessage(\n  "Failed to load track!\n  {exception.message}")
  deactivate AudioLoader
end

' ═══════════════════════════════════════════════════════
== Slash Command: /skip ==
' ═══════════════════════════════════════════════════════

User -> Discord : /skip
Discord -> Listener : SlashCommandInteractionEvent
activate Listener
Listener -> Handler : dispatch → SlashSkipCommandHandler\n  handle(event, guild)
activate Handler
Handler -> Registry : getOrCreate(guildId)
Registry --> Handler : GuildMusicManager (manager)
Handler -> Scheduler : manager.getTrackScheduler().skip()
activate Scheduler
alt Queue has a next track
  Scheduler -> LLClient : link.createOrUpdatePlayer()\n  .setTrack(next)\n  .setVolume(50)\n  .setEndTime(next.length)\n  .subscribe()
else Queue is empty
  Scheduler -> LLClient : link.createOrUpdatePlayer()\n  .setTrack(null)\n  .subscribe()
end
deactivate Scheduler
Handler -> Discord : reply("Skipped the current track!").queue()
deactivate Handler
deactivate Listener

' ═══════════════════════════════════════════════════════
== Slash Command: /loop ==
' ═══════════════════════════════════════════════════════

User -> Discord : /loop
Discord -> Listener : SlashCommandInteractionEvent
activate Listener
Listener -> Handler : dispatch → SlashLoopCommandHandler\n  handle(event, guild)
activate Handler
Handler -> Registry : getOrCreate(guildId)
Registry --> Handler : GuildMusicManager (manager)
Handler -> Scheduler : getTrackScheduler().getLoopMode()
Scheduler --> Handler : currentMode
Handler -> Handler : newMode = currentMode.next()
Handler -> Scheduler : setLoopMode(newMode)
note right of Handler : Cycle: DISABLED → TRACK → QUEUE → DISABLED
alt newMode = TRACK
  Handler -> Discord : reply("🔂 Loop track enabled!").queue()
else newMode = QUEUE
  Handler -> Discord : reply("🔁 Loop queue enabled!").queue()
else newMode = DISABLED
  Handler -> Discord : reply("Loop disabled!").queue()
end
deactivate Handler
deactivate Listener

' ═══════════════════════════════════════════════════════
== Slash Command: /stop ==
' ═══════════════════════════════════════════════════════

User -> Discord : /stop
Discord -> Listener : SlashCommandInteractionEvent
activate Listener
Listener -> Handler : dispatch → SlashStopCommandHandler\n  handle(event, guild)
activate Handler
Handler -> Registry : getOrCreate(guildId)
Registry --> Handler : GuildMusicManager (manager)
Handler -> MusicManager : manager.stop()
activate MusicManager
MusicManager -> Scheduler : trackScheduler.clearQueue()
MusicManager -> LLClient : player.setPaused(false)\n  .setTrack(null)\n  .subscribe()
deactivate MusicManager
Handler -> Discord : reply("Stopped the current track!").queue()
deactivate Handler
deactivate Listener

' ═══════════════════════════════════════════════════════
== Slash Command: /leave ==
' ═══════════════════════════════════════════════════════

User -> Discord : /leave
Discord -> Listener : SlashCommandInteractionEvent
activate Listener
Listener -> Handler : dispatch → SlashLeaveCommandHandler\n  handle(event, guild)
activate Handler
Handler -> Discord : jda.getDirectAudioController()\n  .disconnect(guild)
Handler -> Registry : remove(guildId)
Handler -> Discord : reply("Leaving the channel!").queue()
deactivate Handler
deactivate Listener

' ═══════════════════════════════════════════════════════
== Track Lifecycle: TrackStartEvent ==
' ═══════════════════════════════════════════════════════

LLNode -> LLClient : TrackStartEvent (guildId, track)
LLClient -> Listener : TrackStartEvent subscriber (from init())
activate Listener
Listener -> Registry : managers.get(guildId)
Registry --> Listener : GuildMusicManager (if present)
Listener -> Scheduler : trackScheduler.onTrackStart(event)
activate Scheduler
Scheduler -> Scheduler : log "[Guild guildId]\n  Track started: <title>"
deactivate Scheduler
deactivate Listener

' Also fires to infrastructure listener in LavalinkConfiguration
LLClient -> LLClient : EmittedEvent subscriber:\n  log "Node '<name>' emitted event"

' ═══════════════════════════════════════════════════════
== Track Lifecycle: TrackEndEvent ==
' ═══════════════════════════════════════════════════════

LLNode -> LLClient : TrackEndEvent (guildId, track, endReason)
LLClient -> Listener : TrackEndEvent subscriber (from init())
activate Listener
Listener -> Registry : managers.get(guildId)
Registry --> Listener : GuildMusicManager (if present)
Listener -> Scheduler : trackScheduler.onTrackEnd(event)
activate Scheduler
Scheduler -> Scheduler : log "[Guild guildId]\n  Track ended: <title> (reason: <endReason>)"

alt endReason.getMayStartNext() = false
  Scheduler -> Scheduler : return (STOPPED — do nothing)
else loopMode = TRACK
  Scheduler -> Scheduler : startTrack(endedTrack)
else loopMode = QUEUE
  Scheduler -> Scheduler : queue.offer(endedTrack)
  Scheduler -> Scheduler : startTrack(queue.poll())
else loopMode = DISABLED
  Scheduler -> Scheduler : startNextQueueTrack()\n  (queue.poll() → startTrack if present)
end

deactivate Scheduler
deactivate Listener

' ═══════════════════════════════════════════════════════
== Observability: Health Probe ==
' ═══════════════════════════════════════════════════════

User -> Actuator : GET :54001/actuator/health
activate Actuator
Actuator --> User : 200 OK\n{\n  "status": "UP",\n  "liveness": "CORRECT",\n  "readiness": "ACCEPTING_TRAFFIC"\n}
deactivate Actuator

' ═══════════════════════════════════════════════════════
== Observability: Metrics Export ==
' ═══════════════════════════════════════════════════════

Actuator -> Elastic : POST metrics (Micrometer / elastic export)\n[requires ELASTIC_PASSWORD env var]
note right of Elastic : management.elastic\n  .metrics.export\n  .enabled=true\n  (management port 54001)

@enduml

